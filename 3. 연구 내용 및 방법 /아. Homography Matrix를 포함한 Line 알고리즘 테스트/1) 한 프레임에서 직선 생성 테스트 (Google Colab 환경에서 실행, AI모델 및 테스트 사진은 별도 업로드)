virtual_points_dict = {
    'A1': (-14.0, 9.95), 'A3': (-14.0, 5.05), 'A2': (-8.2, 9.95), 'A4': (-8.2, 5.05),
    'B1': (-11.01, 14.1), 'B2': (-11.01, 0.9), 'C1': (-5.675, 7.5),
    'P1': (0.0, 15.0), 'P2': (0.0, 9.3),
    'a1': (14.0, 9.95), 'a3': (14.0, 5.05), 'a2': (8.2, 9.95), 'a4': (8.2, 5.05),
    'b1': (11.01, 14.1), 'b2': (11.01, 0.9), 'c1': (5.675, 7.5)
}

def transform_point(pt_screen, H_matrix):
    pt_h = np.array([pt_screen[0], pt_screen[1], 1.0])
    transformed = H_matrix @ pt_h
    return transformed[:2] / transformed[2]

def get_line_eq(p1, p2):
    """두 점을 지나는 직선의 방정식 반환"""
    if abs(p2[0] - p1[0]) < 1e-6: return f"x = {p1[0]:.2f}"
    a = (p2[1] - p1[1]) / (p2[0] - p1[0])
    b = p1[1] - a * p1[0]
    return f"y = {a:.3f}x + ({b:.3f})"

def draw_full_virtual_court(ax, line_color, bg_color):
    """제공해주신 농구장 풀 디테일 그리기 로직"""
    COURT_HALF_L = 14.0; COURT_W = 15.0; HOOP_OFFSET = 1.575
    PAINT_L = 5.8; PAINT_W = 4.9; FREE_THROW_RADIUS = 1.8
    THREE_PT_RADIUS = 6.75; THREE_PT_STRAIGHT = 2.99; THREE_PT_MARGIN = 0.9
    CENTER_CIRCLE_RADIUS = 1.8

    ax.add_patch(Rectangle((-COURT_HALF_L, 0), COURT_HALF_L*2, COURT_W, fill=False, lw=1.5, color=line_color))
    ax.plot([0, 0], [0, COURT_W], lw=1.5, color=line_color, linestyle='--')
    ax.add_patch(Circle((0, COURT_W/2), CENTER_CIRCLE_RADIUS, fill=True, color=line_color, alpha=0.1))
    ax.add_patch(Circle((0, COURT_W/2), CENTER_CIRCLE_RADIUS, fill=False, lw=1.5, color=line_color))

    def draw_half(is_left=True):
        sign = 1 if is_left else -1
        base_x = -COURT_HALF_L if is_left else COURT_HALF_L
        hoop_x = base_x + sign * HOOP_OFFSET
        paint_y = (COURT_W - PAINT_W) / 2
        rect_x = base_x if is_left else base_x - PAINT_L
        ax.add_patch(Rectangle((rect_x, paint_y), PAINT_L, PAINT_W, fill=False, lw=1.5, color=line_color))
        ft_center_x = base_x + sign * PAINT_L
        ax.add_patch(Arc((ft_center_x, COURT_W/2), FREE_THROW_RADIUS*2, FREE_THROW_RADIUS*2,
                         theta1=270 if is_left else 90, theta2=90 if is_left else 270, lw=1.5, color=line_color))
        ax.add_patch(Arc((ft_center_x, COURT_W/2), FREE_THROW_RADIUS*2, FREE_THROW_RADIUS*2,
                         theta1=90 if is_left else 270, theta2=270 if is_left else 90, lw=1.5, color=line_color, linestyle=':'))
        ax.plot([base_x, base_x + sign * THREE_PT_STRAIGHT], [THREE_PT_MARGIN, THREE_PT_MARGIN], lw=1.5, color=line_color)
        ax.plot([base_x, base_x + sign * THREE_PT_STRAIGHT], [COURT_W - THREE_PT_MARGIN, COURT_W - THREE_PT_MARGIN], lw=1.5, color=line_color)
        angle = np.arcsin((COURT_W/2 - THREE_PT_MARGIN) / THREE_PT_RADIUS) * 180 / np.pi
        if is_left:
            ax.add_patch(Arc((hoop_x, COURT_W/2), THREE_PT_RADIUS*2, THREE_PT_RADIUS*2, theta1=-angle, theta2=angle, lw=1.5, color=line_color))
        else:
            ax.add_patch(Arc((hoop_x, COURT_W/2), THREE_PT_RADIUS*2, THREE_PT_RADIUS*2, theta1=180-angle, theta2=180+angle, lw=1.5, color=line_color))

    draw_half(True); draw_half(False)
    for name, (px, py) in virtual_points_dict.items():
        pt_color = '#ff0055' if name.isupper() else '#00ffcc'
        ax.plot(px, py, marker='x', color=pt_color, markersize=8, markeredgewidth=2)
        ax.text(px + (-0.8 if name.isupper() else 0.3), py + 0.4, name, fontsize=10, color='#e0f7fa', fontweight='bold')

